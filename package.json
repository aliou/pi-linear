{
  "name": "@aliou/pi-linear",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "private": false,
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "linear"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aliou/pi-linear"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "schema.json",
    "README.md"
  ],
  "dependencies": {
    "@aliou/pi-utils-settings": "^0.11.0",
    "@aliou/pi-utils-ui": "^0.1.0",
    "@aliou/sh": "^0.1.0",
    "@linear/sdk": "^77.0.0",
    "@sinclair/typebox": "^0.34.48"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "0.62.0",
    "@mariozechner/pi-tui": "0.62.0"
  },
  "devDependencies": {
    "@aliou/biome-plugins": "^0.3.2",
    "@biomejs/biome": "^2.3.13",
    "@changesets/cli": "^2.27.11",
    "@mariozechner/pi-ai": "0.62.0",
    "@mariozechner/pi-coding-agent": "0.62.0",
    "@types/node": "^25.0.10",
    "husky": "^9.1.7",
    "ts-json-schema-generator": "^2.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "@mariozechner/pi-ai": "$@mariozechner/pi-coding-agent",
      "@mariozechner/pi-tui": "$@mariozechner/pi-coding-agent"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome check --write",
    "gen:schema": "ts-json-schema-generator --path src/config.ts --type LinearConfig --no-type-check -o schema.json",
    "check:schema": "ts-json-schema-generator --path src/config.ts --type LinearConfig --no-type-check -o /tmp/schema-check.json && diff -q schema.json /tmp/schema-check.json",
    "check:lockfile": "pnpm install --frozen-lockfile --ignore-scripts",
    "prepare": "[ -d .git ] && husky || true",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm changeset publish"
  },
  "packageManager": "pnpm@10.26.1",
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@mariozechner/pi-tui": {
      "optional": true
    }
  }
}
